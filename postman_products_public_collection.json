{
  "info": {
    "_postman_id": "b4ce78b0-0ad4-4f3d-9b1a-f0f598328f52",
    "name": "Coupony Public Products API",
    "description": "Public Product and Category browsing endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?category={{category_id}}&search=&featured=&per_page=15",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "{{category_id}}"
                },
                {
                  "key": "search",
                  "value": ""
                },
                {
                  "key": "featured",
                  "value": ""
                },
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Show Product",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{product_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{product_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "categories"
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Category Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/categories/{{category_id}}/products?per_page=15",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "categories",
                "{{category_id}}",
                "products"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
