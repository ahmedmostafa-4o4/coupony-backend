{
  "info": {
    "_postman_id": "9f2ff221-dc5b-4f5b-87a7-9f8df59b0aa1",
    "name": "Coupony Marketplace Refactor API",
    "description": "Postman collection for the refactored marketplace flows: public catalog, seller product submissions, admin revision review, customer claims, and store employee redemption/history. Pricing note: sellers now submit variant original_price only. The backend resolves variant price and compare_at_price from the offer for fixed and percentage offers, while buy_x_get_y keeps pricing as reference data.",
