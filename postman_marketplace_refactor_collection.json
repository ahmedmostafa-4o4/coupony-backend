    },
    {
      "name": "Seller Product Flow",
      "item": [
        {
          "name": "Create Product With Fixed Offer",
          "request": {
            "description": "Creates a seller product submission using the current pricing contract. Do not send variant price or compare_at_price. Send variants.*.original_price and let the backend resolve stored price fields from the fixed offer.",
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Marketplace Fixed Offer Product\",\n  \"slug\": \"marketplace-fixed-offer-product\",\n  \"short_description\": \"Short description\",\n  \"description\": \"Long description\",\n  \"currency\": \"EGP\",\n  \"sku\": \"MKT-FIXED-001\",\n  \"is_featured\": false,\n  \"category_ids\": [{{category_id}}],\n  \"images\": [],\n  \"variants\": [\n    {\n      \"title\": \"Red / XL\",\n      \"option_summary\": \"Color: Red, Size: XL\",\n      \"sku\": \"MKT-FIXED-001-RED-XL\",\n      \"barcode\": \"123456789\",\n      \"original_price\": 110,\n      \"currency\": \"EGP\",\n      \"sort_order\": 0,\n      \"is_default\": true,\n      \"is_active\": true,\n      \"inventory_mode\": \"tracked\",\n      \"stock_qty\": 8,\n      \"low_stock_threshold\": 2,\n      \"allow_backorder\": false,\n      \"attributes\": [\n        { \"attribute_name\": \"color\", \"attribute_value\": \"red\", \"sort_order\": 0 },\n        { \"attribute_name\": \"size\", \"attribute_value\": \"XL\", \"sort_order\": 1 }\n      ]\n    }\n  ],\n  \"offer\": {\n    \"type\": \"fixed\",\n    \"status\": \"active\",\n    \"label\": \"Launch discount\",\n    \"claim_expiration_minutes\": 1440,\n    \"fixed_amount\": 15,\n    \"percentage_value\": null,\n    \"max_discount\": null,\n    \"buy_qty\": null,\n    \"get_qty\": null,\n    \"allow_mix_buy_variants\": false,\n    \"allow_mix_reward_variants\": false,\n    \"buy_variant_skus\": [],\n    \"reward_variant_skus\": []\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('product_id', json?.data?.id || '');",
                  "  pm.collectionVariables.set('variant_id', json?.data?.variants?.[0]?.id || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List Seller Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products?per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products"],
              "query": [{ "key": "per_page", "value": "15" }]
            }
          }
        },
        {
          "name": "Show Seller Product",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products/{{product_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Update Product To Create Pending Revision",
          "request": {
            "description": "Creates or updates the single pending revision for an already approved product. Live catalog data remains unchanged until admin approval.",
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Marketplace Fixed Offer Product Pending Edit\",\n  \"offer\": {\n    \"type\": \"percentage\",\n    \"status\": \"active\",\n    \"label\": \"Pending review percentage offer\",\n    \"claim_expiration_minutes\": 720,\n    \"fixed_amount\": null,\n    \"percentage_value\": 20,\n    \"max_discount\": 50,\n    \"buy_qty\": null,\n    \"get_qty\": null,\n    \"allow_mix_buy_variants\": false,\n    \"allow_mix_reward_variants\": false,\n    \"buy_variant_skus\": [],\n    \"reward_variant_skus\": []\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products/{{product_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "List Seller Revisions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products/{{product_id}}/revisions?per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products", "{{product_id}}", "revisions"],
              "query": [{ "key": "per_page", "value": "15" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('revision_id', json?.data?.[0]?.id || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Show Seller Revision",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products/{{product_id}}/revisions/{{revision_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products", "{{product_id}}", "revisions", "{{revision_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Revision Review",
      "item": [
