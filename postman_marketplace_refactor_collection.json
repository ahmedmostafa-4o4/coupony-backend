            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/products/revisions/{{revision_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "products", "revisions", "{{revision_id}}"]
            }
          }
        },
        {
          "name": "Approve Product Revision",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Approved for publishing\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/products/revisions/{{revision_id}}/approve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "products", "revisions", "{{revision_id}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Product Revision",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Offer details need changes\",\n  \"notes\": \"Please revise and resubmit\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/products/revisions/{{revision_id}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "products", "revisions", "{{revision_id}}", "reject"]
            }
          }
        }
      ]
    },
    {
      "name": "Customer Claims",
      "item": [
        {
          "name": "Create Claim For Fixed Or Percentage Offer",
          "request": {
            "description": "Creates a QR claim from a live approved product offer. Stock is not deducted here; deduction happens only on successful redemption.",
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variant_ids\": [\"{{variant_id}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{product_id}}/claims",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{product_id}}", "claims"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('claim_id', json?.data?.id || '');",
                  "  pm.collectionVariables.set('qr_code_token', json?.data?.qr_code_token || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Buy X Get Y Product",
          "request": {
            "description": "Creates a buy_x_get_y product submission. Variants still submit original_price only; no synthetic discount price is sent by the seller.",
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{seller_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Marketplace Buy X Get Y Product\",\n  \"slug\": \"marketplace-buy-x-get-y-product\",\n  \"short_description\": \"Short description\",\n  \"description\": \"Long description\",\n  \"currency\": \"EGP\",\n  \"sku\": \"MKT-BXGY-001\",\n  \"is_featured\": false,\n  \"category_ids\": [{{category_id}}],\n  \"images\": [],\n  \"variants\": [\n    {\n      \"title\": \"Buy Variant A\",\n      \"option_summary\": \"Buy A\",\n      \"sku\": \"MKT-BXGY-BUY-A\",\n      \"original_price\": 100,\n      \"currency\": \"EGP\",\n      \"sort_order\": 0,\n      \"is_default\": true,\n      \"is_active\": true,\n      \"inventory_mode\": \"tracked\",\n      \"stock_qty\": 6,\n      \"low_stock_threshold\": 2,\n      \"allow_backorder\": false,\n      \"attributes\": []\n    },\n    {\n      \"title\": \"Buy Variant B\",\n      \"option_summary\": \"Buy B\",\n      \"sku\": \"MKT-BXGY-BUY-B\",\n      \"original_price\": 100,\n      \"currency\": \"EGP\",\n      \"sort_order\": 1,\n      \"is_default\": false,\n      \"is_active\": true,\n      \"inventory_mode\": \"tracked\",\n      \"stock_qty\": 6,\n      \"low_stock_threshold\": 2,\n      \"allow_backorder\": false,\n      \"attributes\": []\n    },\n    {\n      \"title\": \"Reward Variant\",\n      \"option_summary\": \"Reward\",\n      \"sku\": \"MKT-BXGY-REWARD\",\n      \"original_price\": 0,\n      \"currency\": \"EGP\",\n      \"sort_order\": 2,\n      \"is_default\": false,\n      \"is_active\": true,\n      \"inventory_mode\": \"tracked\",\n      \"stock_qty\": 3,\n      \"low_stock_threshold\": 1,\n      \"allow_backorder\": false,\n      \"attributes\": []\n    }\n  ],\n  \"offer\": {\n    \"type\": \"buy_x_get_y\",\n    \"status\": \"active\",\n    \"label\": \"Buy 2 get 1\",\n    \"claim_expiration_minutes\": 1440,\n    \"fixed_amount\": null,\n    \"percentage_value\": null,\n    \"max_discount\": null,\n    \"buy_qty\": 2,\n    \"get_qty\": 1,\n    \"allow_mix_buy_variants\": true,\n    \"allow_mix_reward_variants\": false,\n    \"buy_variant_skus\": [\"MKT-BXGY-BUY-A\", \"MKT-BXGY-BUY-B\"],\n    \"reward_variant_skus\": [\"MKT-BXGY-REWARD\"]\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/stores/{{store_id}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stores", "{{store_id}}", "products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const variants = json?.data?.variants || [];",
                  "  pm.collectionVariables.set('bxgy_product_id', json?.data?.id || '');",
                  "  pm.collectionVariables.set('buy_variant_1_id', variants?.[0]?.id || '');",
                  "  pm.collectionVariables.set('buy_variant_2_id', variants?.[1]?.id || '');",
                  "  pm.collectionVariables.set('reward_variant_id', variants?.[2]?.id || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Buy X Get Y Claim",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buy_variant_ids\": [\"{{buy_variant_1_id}}\", \"{{buy_variant_2_id}}\"],\n  \"reward_variant_ids\": [\"{{reward_variant_id}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{bxgy_product_id}}/claims",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products", "{{bxgy_product_id}}", "claims"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('bxgy_claim_id', json?.data?.id || '');",
                  "  pm.collectionVariables.set('bxgy_qr_code_token', json?.data?.qr_code_token || '');",
                  "}"
