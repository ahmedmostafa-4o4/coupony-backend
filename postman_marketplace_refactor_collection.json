    {
      "name": "Public Catalog",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?category={{category_id}}&search=&featured=&per_page=15",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "category", "value": "{{category_id}}" },
                { "key": "search", "value": "" },
                { "key": "featured", "value": "" },
                { "key": "per_page", "value": "15" }
              ]
