{
	"info": {
		"_postman_id": "a2e8c1f4-3d18-4c28-98e6-12a832c3f1b5",
		"name": "Categories & Followed Stores",
		"description": "Endpoints for fetching products by category and listing user followed stores filtered by category.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Public - Categories & Products",
			"item": [
				{
					"name": "Get Products by Category",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/categories/{{category_id}}/products?per_page=15",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"categories",
								"{{category_id}}",
								"products"
							],
							"query": [
								{
									"key": "per_page",
									"value": "15"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Customer - Followed Stores",
			"item": [
				{
					"name": "Get Followed Stores (Filtered by Category)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{user_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/me/followed-stores?category_id={{category_id}}&per_page=15",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"me",
								"followed-stores"
							],
							"query": [
								{
									"key": "category_id",
									"value": "{{category_id}}",
									"description": "Optional: Filter stores by category ID"
								},
								{
									"key": "per_page",
									"value": "15"
								}
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		},
		{
			"key": "user_token",
			"value": "your-customer-token"
		},
		{
			"key": "category_id",
			"value": "1"
		}
	]
}
