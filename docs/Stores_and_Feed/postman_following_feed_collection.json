		{
			"name": "Following Feed (Guest User - Trending)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"pm.test(\"Verify all items are trending source type\", function () {",
							"    var jsonData = pm.response.json();",
							"    jsonData.data.items.forEach(function(item) {",
							"        pm.expect(item.source_type).to.equal('trending');",
							"    });",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/json",
						"type": "text"
