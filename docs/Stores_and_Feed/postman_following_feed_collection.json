				],
				"url": {
					"raw": "{{base_url}}/api/v1/customer/home/following-feed",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"customer",
						"home",
						"following-feed"
					]
				},
				"description": "Accesses the following feed as a guest user (unauthenticated). Returns trending items only."
			},
