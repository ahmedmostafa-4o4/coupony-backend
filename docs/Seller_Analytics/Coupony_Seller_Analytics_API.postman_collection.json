							"raw": "{{base_url}}/api/v1/stores/{{store_id}}/analytics?period=invalid_value",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stores", "{{store_id}}", "analytics"],
							"query": [
								{
									"key": "period",
									"value": "invalid_value"
								}
							]
						},
						"description": "Test validation: invalid period value returns 422.\n\nValid values: all, today, last_7_days, this_month, this_year"
					},
