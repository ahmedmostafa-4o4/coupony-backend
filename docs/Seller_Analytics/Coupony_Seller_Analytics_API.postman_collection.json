		{
			"name": "Monthly Goal",
			"description": "Monthly goal management endpoint",
			"item": [
				{
					"name": "Update Monthly Goal",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "en"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"goal\": 150\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/stores/{{store_id}}/analytics/monthly-goal",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stores", "{{store_id}}", "analytics", "monthly-goal"]
						},
						"description": "Set or update the seller's monthly redemption goal.\n\nThe goal must be a positive integer (min: 1).\n\nUpdating the goal invalidates the cached dashboard for all periods."
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"goal\": 150\n}"
						},
						{
							"name": "Validation Error - Zero",
							"status": "Unprocessable Entity",
							"code": 422,
							"body": "{\n  \"message\": \"The goal field must be at least 1.\",\n  \"errors\": {\n    \"goal\": [\n      \"The goal field must be at least 1.\"\n    ]\n  }\n}"
						},
						{
							"name": "Validation Error - Missing",
							"status": "Unprocessable Entity",
							"code": 422,
							"body": "{\n  \"message\": \"The goal field is required.\",\n  \"errors\": {\n    \"goal\": [\n      \"The goal field is required.\"\n    ]\n  }\n}"
						},
						{
							"name": "Validation Error - Not Integer",
							"status": "Unprocessable Entity",
							"code": 422,
							"body": "{\n  \"message\": \"The goal field must be an integer.\",\n  \"errors\": {\n    \"goal\": [\n      \"The goal field must be an integer.\"\n    ]\n  }\n}"
						}
					]
				}
			]
		},
		{
			"name": "Product Analytics",
			"description": "Per-product analytics endpoints",
			"item": [
				{
					"name": "Get Product Analytics (All Time)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "en"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/stores/{{store_id}}/analytics/products/{{product_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stores", "{{store_id}}", "analytics", "products", "{{product_id}}"]
						},
						"description": "Get detailed analytics for a specific product (all time).\n\nThe product must belong to the authenticated seller's store.\n\nReturns: header (views, likes, comments, saves), overview (impressions, reach, traffic sources), engagement (rate, trend, breakdown), audience (follower split, age groups, gender)."
					},
					"response": [
						{
							"name": "Success - With Data",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"header\": {\n    \"views\": 1500,\n    \"likes\": 230,\n    \"comments\": 45,\n    \"saves\": 89\n  },\n  \"overview\": {\n    \"impressions\": 5000,\n    \"reached_accounts\": 3200,\n    \"profile_visits\": 180,\n    \"new_followers\": 12,\n    \"traffic_sources\": [\n      { \"source\": \"search\", \"percentage\": 40.0 },\n      { \"source\": \"explore\", \"percentage\": 25.0 },\n      { \"source\": \"profile\", \"percentage\": 20.0 },\n      { \"source\": \"direct\", \"percentage\": 10.0 },\n      { \"source\": \"recommendation\", \"percentage\": 5.0 }\n    ]\n  },\n  \"engagement\": {\n    \"total_interactions\": 364,\n    \"engagement_rate\": 7.28,\n    \"trend\": [\n      { \"date\": \"2025-01\", \"count\": 120 },\n      { \"date\": \"2025-02\", \"count\": 145 },\n      { \"date\": \"2025-03\", \"count\": 99 }\n    ],\n    \"action_breakdown\": {\n      \"likes\": 230,\n      \"comments\": 45,\n      \"saves\": 89,\n      \"shares\": 0\n    }\n  },\n  \"audience\": {\n    \"followers_percent\": 65.0,\n    \"non_followers_percent\": 35.0,\n    \"age_groups\": [\n      { \"range\": \"13-17\", \"percentage\": 5.0 },\n      { \"range\": \"18-24\", \"percentage\": 35.0 },\n      { \"range\": \"25-34\", \"percentage\": 30.0 },\n      { \"range\": \"35-44\", \"percentage\": 15.0 },\n      { \"range\": \"45-54\", \"percentage\": 8.0 },\n      { \"range\": \"55-64\", \"percentage\": 5.0 },\n      { \"range\": \"65+\", \"percentage\": 2.0 }\n    ],\n    \"gender_groups\": [\n      { \"gender\": \"male\", \"percentage\": 55.0 },\n      { \"gender\": \"female\", \"percentage\": 42.0 },\n      { \"gender\": \"other\", \"percentage\": 3.0 }\n    ]\n  }\n}"
						},
						{
							"name": "Success - Zero Data",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"header\": {\n    \"views\": 0,\n    \"likes\": 0,\n    \"comments\": 0,\n    \"saves\": 0\n  },\n  \"overview\": {\n    \"impressions\": 0,\n    \"reached_accounts\": 0,\n    \"profile_visits\": 0,\n    \"new_followers\": 0,\n    \"traffic_sources\": []\n  },\n  \"engagement\": {\n    \"total_interactions\": 0,\n    \"engagement_rate\": 0.0,\n    \"trend\": [],\n    \"action_breakdown\": {\n      \"likes\": 0,\n      \"comments\": 0,\n      \"saves\": 0,\n      \"shares\": 0\n    }\n  },\n  \"audience\": {\n    \"followers_percent\": 50.0,\n    \"non_followers_percent\": 50.0,\n    \"age_groups\": [\n      { \"range\": \"13-17\", \"percentage\": 14.3 },\n      { \"range\": \"18-24\", \"percentage\": 14.3 },\n      { \"range\": \"25-34\", \"percentage\": 14.3 },\n      { \"range\": \"35-44\", \"percentage\": 14.3 },\n      { \"range\": \"45-54\", \"percentage\": 14.3 },\n      { \"range\": \"55-64\", \"percentage\": 14.3 },\n      { \"range\": \"65+\", \"percentage\": 14.2 }\n    ],\n    \"gender_groups\": []\n  }\n}"
						},
						{
							"name": "Not Found",
							"status": "Not Found",
							"code": 404,
							"body": "{\n  \"message\": \"Not Found.\"\n}"
						},
						{
							"name": "Forbidden - Product Not In Store",
							"status": "Forbidden",
							"code": 403,
							"body": "{\n  \"message\": \"Forbidden.\"\n}"
						}
					]
				},
