{
	"info": {
		"_postman_id": "coupony-seller-analytics-api-v1",
		"name": "Coupony Seller Analytics API",
		"description": "Seller Product Analytics API for Coupony. Includes store-level dashboard, monthly goal management, and per-product analytics.\n\nAll endpoints require Bearer token authentication (Laravel Sanctum). The authenticated user must own or manage a store.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "https://api.coupony.shop",
			"type": "string"
		},
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "store_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "product_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoint to obtain Bearer token",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.token) {",
									"    pm.collectionVariables.set('auth_token', jsonData.data.token);",
									"    console.log('Token saved to collection variable');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"seller@example.com\",\n    \"password\": \"your-password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/login",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "login"]
						},
						"description": "Login to get a Bearer token. The token is automatically saved to the collection variable `auth_token`.\n\nUse a seller account that owns a store."
					},
					"response": []
				}
			]
		},
		{
			"name": "Seller Dashboard",
			"description": "Store-level analytics dashboard endpoints",
			"item": [
				{
					"name": "Get Dashboard (All Time)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "en"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/stores/{{store_id}}/analytics",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "stores", "{{store_id}}", "analytics"]
						},
						"description": "Get the seller's analytics dashboard with default period (all time).\n\nReturns: monthly_goal, new_followers, store_visits, offer_distribution, peak_redemption_times, top_performing_offers."
					},
					"response": [
						{
							"name": "Success - With Data",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"monthly_goal\": {\n    \"goal\": 100,\n    \"current\": 45,\n    \"achievement_percent\": 45.0,\n    \"growth_percent\": 12.5\n  },\n  \"new_followers\": {\n    \"count\": 23,\n    \"growth_percent\": 0.0\n  },\n  \"store_visits\": {\n    \"count\": 1250,\n    \"growth_percent\": 0.0\n  },\n  \"offer_distribution\": [\n    { \"type\": \"fixed\", \"percentage\": 50.0, \"label\": \"Fixed Discount\" },\n    { \"type\": \"percentage\", \"percentage\": 33.3, \"label\": \"Percentage Off\" },\n    { \"type\": \"buy_x_get_y\", \"percentage\": 16.7, \"label\": \"Buy X Get Y\" }\n  ],\n  \"peak_redemption_times\": [\n    { \"day\": \"monday\", \"time_window\": \"morning\", \"count\": 12 },\n    { \"day\": \"monday\", \"time_window\": \"afternoon\", \"count\": 8 },\n    { \"day\": \"monday\", \"time_window\": \"evening\", \"count\": 5 },\n    { \"day\": \"monday\", \"time_window\": \"night\", \"count\": 1 }\n  ],\n  \"top_performing_offers\": [\n    {\n      \"product_title\": \"Premium Coffee\",\n      \"offer_type\": \"percentage\",\n      \"offer_label\": \"20% Off\",\n      \"usage_count\": 145,\n      \"views\": 320\n    }\n  ]\n}"
						},
						{
							"name": "Success - Zero Data (New Store)",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"monthly_goal\": {\n    \"goal\": null,\n    \"current\": 0,\n    \"achievement_percent\": 0.0,\n    \"growth_percent\": 0.0\n  },\n  \"new_followers\": {\n    \"count\": 0,\n    \"growth_percent\": 0.0\n  },\n  \"store_visits\": {\n    \"count\": 0,\n    \"growth_percent\": 0.0\n  },\n  \"offer_distribution\": [],\n  \"peak_redemption_times\": [\n    { \"day\": \"monday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"monday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"monday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"monday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"tuesday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"tuesday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"tuesday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"tuesday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"wednesday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"wednesday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"wednesday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"wednesday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"thursday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"thursday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"thursday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"thursday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"friday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"friday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"friday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"friday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"saturday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"saturday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"saturday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"saturday\", \"time_window\": \"night\", \"count\": 0 },\n    { \"day\": \"sunday\", \"time_window\": \"morning\", \"count\": 0 },\n    { \"day\": \"sunday\", \"time_window\": \"afternoon\", \"count\": 0 },\n    { \"day\": \"sunday\", \"time_window\": \"evening\", \"count\": 0 },\n    { \"day\": \"sunday\", \"time_window\": \"night\", \"count\": 0 }\n  ],\n  \"top_performing_offers\": []\n}"
						},
						{
							"name": "Unauthorized",
							"status": "Unauthorized",
							"code": 401,
							"body": "{\n  \"message\": \"Unauthenticated.\"\n}"
						},
						{
							"name": "Forbidden - No Store",
							"status": "Forbidden",
							"code": 403,
							"body": "{\n  \"message\": \"Forbidden.\"\n}"
						}
					]
				},
