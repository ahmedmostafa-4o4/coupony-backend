		{
			"name": "Store Profile",
			"description": "Public store profile endpoint with integrated profile view tracking",
			"item": [
				{
					"name": "Get Store Profile (Public)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Accept-Language",
								"value": "en"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/public-stores/{{store_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "public-stores", "{{store_id}}"]
						},
						"description": "Get a public store profile. No authentication required.\n\nAutomatically records a profile view for analytics. If the user is authenticated (Bearer token provided), their user ID is captured in the view.\n\nReturns 404 if the store is not active."
					},
					"response": [
						{
							"name": "Success",
